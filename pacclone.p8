pico-8 cartridge // http://www.pico-8.com
version 43
__lua__


#include vec.lua
#include echoes.lua
#include util.lua

g = {}
g.step = 8

#include enemy.lua
#include player.lua
#include map.lua

level = create_level()

local enemies = {}

function _init()
  log("-- Start --", true)
  add(enemies, create_enemy())
end


function _draw()
  cls()
  draw_level(level)
  player.draw() 

  foreach(enemies, function(enemy)
    enemy.draw()
  end)

  print_echoes()
  draw_debug_gfx()
end

function _update()
  player.upd()
  foreach(enemies, function(enemy)
    enemy.upd(player)
  end)
  
end
